<div class="space-y-10">

  <!-- Welcome / Title Row -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-extrabold text-slate-900 font-outfit">Workspace Dashboard</h1>
      <p class="text-slate-500 mt-1">Track your team progress, projects, and personal tasks.</p>
    </div>
    <div>
      <% if policy(Project).create? %>
        <%= link_to new_project_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold text-sm rounded-xl shadow-md shadow-indigo-100 transition-all font-outfit" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Create Project
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Quick Statistics Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2z"></path></svg>
      </div>
      <div>
        <span class="text-xs text-slate-400 font-semibold tracking-wide uppercase">Active Projects</span>
        <h3 class="text-2xl font-bold text-slate-900 font-outfit mt-0.5"><%= @projects.size %></h3>
      </div>
    </div>

    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      </div>
      <div>
        <span class="text-xs text-slate-400 font-semibold tracking-wide uppercase">Assigned Tasks</span>
        <h3 class="text-2xl font-bold text-slate-900 font-outfit mt-0.5"><%= @assigned_tasks.size %></h3>
      </div>
    </div>

    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      </div>
      <div>
        <span class="text-xs text-slate-400 font-semibold tracking-wide uppercase">Done Tasks</span>
        <h3 class="text-2xl font-bold text-slate-900 font-outfit mt-0.5"><%= @assigned_tasks.select(&:done?).size %></h3>
      </div>
    </div>
  </div>

  <!-- Projects Grid -->
  <div class="space-y-4">
    <h2 class="text-xl font-bold text-slate-900 font-outfit">My Projects</h2>
    <% if @projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @projects.each do |project| %>
          <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between h-56">
            <div>
              <div class="flex items-center justify-between mb-3">
                <span class="px-2.5 py-1 bg-slate-100 rounded-full text-xs font-semibold text-slate-600 uppercase tracking-wide">
                  <%= project.creator == current_user ? "Owner" : "Collaborator" %>
                </span>
                <span class="text-xs text-slate-400 font-medium">Updated <%= time_ago_in_words(project.updated_at) %> ago</span>
              </div>
              <h3 class="text-lg font-bold text-slate-905 font-outfit line-clamp-1"><%= project.title %></h3>
              <p class="text-sm text-slate-500 mt-1 line-clamp-2 leading-relaxed"><%= project.description %></p>
            </div>
            
            <div class="border-t border-slate-100 pt-4 mt-4 flex items-center justify-between">
              <div class="flex gap-4 text-xs text-slate-400 font-medium">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                  <%= project.users.size %>
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                  <%= project.tasks.size %>
                </span>
              </div>
              <%= link_to "View Project", project, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-700 transition" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-white border border-dashed border-slate-300 rounded-2xl">
        <p class="text-slate-400">No active projects found.</p>
        <% if policy(Project).create? %>
          <%= link_to "Create your first project", new_project_path, class: "text-indigo-600 font-medium text-sm hover:underline mt-2 inline-block" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Tasks Section -->
  <div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-slate-200 pb-4">
      <h2 class="text-xl font-bold text-slate-900 font-outfit">My Assigned Tasks</h2>
      
      <!-- Filter Pills -->
      <div class="flex flex-wrap gap-2 text-sm">
        <%= link_to "All", dashboard_path, class: "px-3.5 py-1.5 rounded-full font-medium transition #{params[:status].blank? ? 'bg-indigo-600 text-white shadow-sm shadow-indigo-100' : 'bg-slate-100 hover:bg-slate-200 text-slate-600'}" %>
        <% Task.statuses.keys.each do |st| %>
          <%= link_to st.humanize, dashboard_path(status: st), class: "px-3.5 py-1.5 rounded-full font-medium transition #{params[:status] == st ? 'bg-indigo-600 text-white shadow-sm shadow-indigo-100' : 'bg-slate-100 hover:bg-slate-200 text-slate-600'}" %>
        <% end %>
      </div>
    </div>

    <% if @assigned_tasks.any? %>
      <div class="bg-white border border-slate-200/80 rounded-2xl overflow-hidden shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 text-left">
          <thead class="bg-slate-50">
            <tr>
              <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Task</th>
              <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Project</th>
              <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            <% @assigned_tasks.each do |task| %>
              <% badge_class, dot_class = task_status_styles(task) %>
              <tr class="hover:bg-slate-50/50 transition">
                <td class="px-6 py-4">
                  <div class="font-semibold text-slate-800"><%= task.title %></div>
                  <div class="text-xs text-slate-400 line-clamp-1 max-w-sm mt-0.5"><%= task.description %></div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-sm font-medium text-slate-600"><%= task.project.title %></span>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold <%= badge_class %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= dot_class %>"></span>
                    <%= task.status.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm font-medium">
                  <%= link_to "Open Work", project_tasks_path(task.project), class: "text-indigo-600 hover:text-indigo-700 transition" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 bg-white border border-dashed border-slate-350 rounded-2xl">
        <p class="text-slate-400">No assigned tasks found matching this criteria.</p>
      </div>
    <% end %>
  </div>

</div>
