          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <% if @minimum_password_length %>
            <span class="text-[10px] text-gray-400">(<%= @minimum_password_length %> characters minimum)</span>
>>>>>>> Stashed changes
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "block w-full rounded-xl border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 p-3 text-slate-800 text-sm transition",
              placeholder: "••••••••" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "block w-full rounded-xl border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 p-3 text-slate-800 text-sm transition",
              placeholder: "••••••••" %>
        </div>

        <div>
          <%= f.submit "Create Account",
              class: "block w-full py-3 px-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl shadow-md shadow-indigo-100 hover:shadow-lg transition-all cursor-pointer text-sm font-outfit" %>
        </div>

      <% end %>
    </div>

    <!-- Footer Links -->
    <div class="mt-6 text-center text-sm text-slate-500 space-y-2">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
