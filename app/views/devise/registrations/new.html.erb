<div class="min-h-[80vh] flex items-center justify-center py-12">
  <div class="w-full max-w-md">

    <!-- Logo Badge -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-tr from-indigo-600 to-violet-500 shadow-lg shadow-indigo-200 mb-4">
        <span class="text-white font-extrabold text-2xl font-outfit">T</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 font-outfit">Create your account</h1>
      <p class="text-slate-500 mt-1 text-sm">Join TaskFlow and start collaborating.</p>
    </div>

    <!-- Card -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "block w-full rounded-xl border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 p-3 text-slate-800 text-sm transition",
              placeholder: "you@example.com" %>
        </div>

        <div>
<<<<<<< Updated upstream
          <%= f.label :password, class: "block text-sm font-semibold text-slate-700 mb-1.5" do %>
            Password
            <% if @minimum_password_length %>
              <span class="font-normal text-slate-400 ml-1">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
