<div class="min-h-[80vh] flex items-center justify-center py-12">
  <div class="w-full max-w-md">

    <!-- Logo Badge -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-tr from-indigo-600
        to-violet-500 shadow-lg shadow-indigo-200 mb-4">
        <span class="text-white font-extrabold text-2xl font-outfit">T</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 font-outfit">Welcome back</h1>
      <p class="text-slate-500 mt-1 text-sm">Sign in to your TaskFlow workspace.</p>
    </div>

    <!-- Card -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-8">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f|
        %>

        <div>
          <%= f.label :email, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "block w-full rounded-xl border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white
                focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 p-3 text-slate-800 text-sm transition",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "block w-full rounded-xl border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white
                focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 p-3 text-slate-800 text-sm transition",
              placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
            <%= f.label :remember_me, class: "text-sm font-medium text-slate-600 cursor-pointer" %>
          </div>
        <% end %>

        <div>
          <%= f.submit "Sign in to TaskFlow",
              class: "block w-full py-3 px-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl
                shadow-md shadow-indigo-100 hover:shadow-lg transition-all cursor-pointer text-sm font-outfit" %>
        </div>

      <% end %>
    </div>

    <!-- Footer Links -->
    <div class="mt-6 text-center text-sm text-slate-500 space-y-2">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
