<div class="space-y-2 flex flex-col items-center">
  <%- if controller_name != 'sessions' %>
    <p class="text-sm text-slate-500">
      Already have an account?
      <%= link_to "Sign in instead", new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-700
        font-semibold transition" %>
    </p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p class="text-sm text-slate-500">
      New to TaskFlow?
      <%= link_to "Create an account", new_registration_path(resource_name), class: "text-indigo-600
        hover:text-indigo-700 font-semibold transition" %>
    </p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p class="text-sm">
      <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-slate-500 hover:text-slate-700
        transition" %>
    </p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p class="text-sm">
      <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class:
        "text-slate-500 hover:text-slate-700 transition" %>
    </p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <p class="text-sm">
      <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-slate-500
        hover:text-slate-700 transition" %>
    </p>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <div>
        <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name,
          provider), data: { turbo: false }, class: "px-4 py-2 bg-white border border-slate-200 text-slate-700
          font-semibold text-sm rounded-xl transition hover:bg-slate-50 cursor-pointer" %>
      </div>
    <% end %>
  <% end %>
</div>
