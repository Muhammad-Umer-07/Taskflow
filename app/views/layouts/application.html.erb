<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Taskflow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Taskflow">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Tailwind CDN + Google Fonts -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
              outfit: ['Outfit', 'sans-serif'],
            }
          }
        }
      }
    </script>
    
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col antialiased">
    <!-- Premium Header -->
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-200/80 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        
        <div class="flex items-center gap-8">
          <%= link_to root_path, class: "flex items-center gap-2 group" do %>
            <div class="w-9 h-9 rounded-xl bg-gradient-to-tr from-indigo-600 to-violet-500 flex items-center justify-center text-white font-outfit font-black text-xl shadow-md shadow-indigo-200 group-hover:scale-105 transition-transform duration-200">
              T
            </div>
            <span class="font-outfit font-extrabold text-xl tracking-tight bg-gradient-to-r from-slate-900 to-slate-700 bg-clip-text text-transparent group-hover:from-indigo-600 group-hover:to-violet-600 transition-all duration-300">
              TaskFlow
            </span>
          <% end %>

          <% if user_signed_in? %>
            <nav class="hidden md:flex items-center gap-1">
              <%= link_to "Dashboard", dashboard_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-all" %>
              <%= link_to "Projects", projects_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-all" %>
            </nav>
          <% end %>
        </div>

        <div class="flex items-center gap-4">
          <% if user_signed_in? %>
            <div class="hidden sm:flex flex-col items-end">
              <span class="text-xs text-slate-400 font-medium tracking-wide uppercase"><%= current_user.role %></span>
              <span class="text-sm font-semibold text-slate-700"><%= current_user.email %></span>
            </div>
            <div class="h-8 w-px bg-slate-200 hidden sm:block"></div>
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "px-4 py-2 border border-slate-200 hover:border-slate-300 hover:bg-slate-50 text-slate-700 font-medium text-sm rounded-lg transition-all" %>
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "text-slate-600 hover:text-slate-900 font-medium text-sm transition-all" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm rounded-lg shadow-md shadow-indigo-100 hover:shadow-lg transition-all" %>
          <% end %>
        </div>

      </div>
    </header>

    <!-- Notification Toast Messages -->
    <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 mt-4">
      <% if notice %>
        <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-800 text-sm font-medium flex items-center gap-2 shadow-sm animate-fade-in">
          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="p-4 rounded-xl bg-rose-50 border border-rose-100 text-rose-800 text-sm font-medium flex items-center gap-2 shadow-sm animate-fade-in">
          <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          <%= alert %>
        </div>
      <% end %>
    </div>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <!-- Premium Footer -->
    <footer class="bg-white border-t border-slate-200 mt-auto py-6">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <div>
          &copy; <%= Time.current.year %> TaskFlow. Built for high performance collaboration.
        </div>
        <div class="flex gap-4">
          <a href="#" class="hover:text-slate-800 transition-colors">Privacy</a>
          <a href="#" class="hover:text-slate-800 transition-colors">Terms</a>
          <a href="#" class="hover:text-slate-800 transition-colors">Status</a>
        </div>
      </div>
    </footer>
  </body>
</html>
