<div class="space-y-10 max-w-5xl mx-auto">
  <!-- Back link & Actions Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-slate-200 pb-6">
    <div>
      <%= link_to projects_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-800 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to projects
      <% end %>
      <h1 class="text-3xl font-extrabold text-slate-900 font-outfit mt-3"><%= @project.title %></h1>
      <p class="text-slate-500 mt-1">Created by <span class="font-medium text-slate-700"><%= @project.creator.email %></span></p>
    </div>
    
    <div class="flex flex-wrap items-center gap-3">
      <% if policy(@project).manage_members? %>
        <%= link_to "Edit Project", edit_project_path(@project), class: "px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-700 font-semibold text-sm rounded-xl transition" %>
      <% end %>

      <% if policy(@project).destroy? %>
        <%= button_to "Delete Project", @project, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this project?" }, class: "px-4 py-2 bg-rose-50 border border-rose-100 hover:bg-rose-100 hover:border-rose-200 text-rose-700 font-semibold text-sm rounded-xl transition cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <!-- Description Section -->
  <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Project Description</h2>
    <p class="text-slate-700 leading-relaxed"><%= @project.description %></p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
    
    <!-- Left 2 Cols: Members & Tasks Navigation -->
    <div class="lg:col-span-2 space-y-10">
      
      <!-- Tasks Panel Link -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold font-outfit text-slate-905">Project Workflow & Kanban</h2>
          <p class="text-sm text-slate-500 mt-0.5">Currently tracking <span class="font-semibold text-slate-750"><%= @project.tasks.count %> tasks</span> for this workspace.</p>
        </div>
        <%= link_to project_tasks_path(@project), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-750 text-white font-semibold text-sm rounded-xl transition shadow-md shadow-indigo-150" do %>
          Open Tasks
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        <% end %>
      </div>

      <!-- Team Members Section -->
      <div class="space-y-4">
        <h2 class="text-lg font-bold font-outfit text-slate-900">Project Workspace Team</h2>
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
          <table class="min-w-full divide-y divide-slate-100 text-left">
            <thead class="bg-slate-50">
              <tr>
                <th scope="col" class="px-6 py-3.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Email Address</th>
                <th scope="col" class="px-6 py-3.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Workspace Role</th>
                <th scope="col" class="px-6 py-3.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
              <% @project.project_memberships.each do |membership| %>
                <tr class="hover:bg-slate-50/50 transition">
                  <td class="px-6 py-4">
                    <span class="font-semibold text-slate-750 text-sm"><%= membership.user.email %></span>
                  </td>
                  <td class="px-6 py-4">
                    <% if membership.user.admin? %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-violet-50 text-violet-700">
                        Admin
                      </span>
                    <% elsif membership.manager? %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700">
                        Manager
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                        Member
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-sm font-semibold">
                    <% if policy(@project).update? && membership.user != @project.creator %>
                      <%= button_to "Remove", project_project_membership_path(@project, membership), method: :delete, data: { turbo_confirm: "Are you sure you want to remove this member from the project?" }, class: "text-rose-600 hover:text-rose-800 transition cursor-pointer" %>
                    <% else %>
                      <span class="text-slate-300 font-normal text-xs">System protected</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- Right Col: Invite Block -->
    <div>
      <% if policy(@project).update? %>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-6">
          <div>
            <h2 class="text-lg font-bold font-outfit text-slate-900">Add Team Member</h2>
            <p class="text-xs text-slate-400 mt-0.5">Invite an existing user to collaborate on this workspace.</p>
          </div>

          <%= form_with url: project_project_memberships_path(@project), scope: nil, class: "space-y-4" do |form| %>
            <div>
              <%= form.label :user_id, "User Email", class: "block text-xs font-semibold text-slate-650 mb-1.5" %>
              <%= form.collection_select :user_id,
                                         @available_members,
                                         :id,
                                         :email,
                                         { prompt: "Choose a member" },
                                         required: true,
                                         class: "block w-full rounded-xl border border-slate-200 text-sm bg-slate-50/50 p-2 text-slate-700" %>
            </div>

            <% if current_user.admin? %>
              <div>
                <%= form.label :role, "Project Role", class: "block text-xs font-semibold text-slate-650 mb-1.5" %>
                <%= form.select :role, [["Member", "member"], ["Manager", "manager"]], {}, class: "block w-full rounded-xl border border-slate-200 text-sm bg-slate-50/50 p-2 text-slate-700" %>
              </div>
            <% end %>

            <%= form.submit "Assign Member", class: "block w-full px-4 py-2.5 bg-indigo-650 hover:bg-indigo-750 text-white font-semibold text-sm rounded-xl transition shadow-md shadow-indigo-100 mt-4 cursor-pointer" %>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>
</div>
