<%= form_with(model: [project, task], class: "space-y-6") do |form| %>
  <% if task.errors.any? %>
    <div class="p-4 bg-rose-50 border border-rose-100 rounded-xl text-rose-800 text-sm">
      <h2 class="font-semibold mb-2"><%= pluralize(task.errors.count, "error") %> prohibited this task from being
        saved:</h2>
      <ul class="list-disc list-inside space-y-1">
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% permitted_attrs = policy(task).permitted_attributes %>

  <!-- Title & Description Form Inputs -->
  <% if permitted_attrs.include?(:title) %>
    <div>
      <%= form.label :title, class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= form.text_field :title, maxlength: Task::TITLE_MAX_LENGTH, class: "block w-full rounded-xl border
        border-slate-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 bg-slate-50/50 hover:bg-slate-50
        transition p-3 text-slate-800", placeholder: "Design system mockups..." %>
    </div>
  <% else %>
    <div class="p-4 bg-slate-50 border border-slate-200 rounded-xl">
      <span class="text-xs text-slate-400 font-semibold uppercase">Task Title</span>
      <h4 class="font-semibold text-slate-700 mt-1"><%= task.title %></h4>
    </div>
  <% end %>

  <% if permitted_attrs.include?(:description) %>
    <div>
      <%= form.label :description, class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= form.text_area :description, rows: 4, maxlength: Task::DESCRIPTION_MAX_LENGTH, class: "block w-full rounded-xl
        border border-slate-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 bg-slate-50/50 hover:bg-slate-50
        transition p-3 text-slate-800", placeholder: "Describe the requirements..." %>
    </div>
  <% else %>
    <% if task.description.present? %>
      <div class="p-4 bg-slate-50 border border-slate-200 rounded-xl">
        <span class="text-xs text-slate-400 font-semibold uppercase">Description</span>
        <p class="text-slate-600 mt-1 text-sm"><%= task.description %></p>
      </div>
    <% end %>
  <% end %>

  <!-- Assignee & Status Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <% if permitted_attrs.include?(:assignee_id) %>
      <div>
        <%= form.label :assignee_id, "Assignee", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= form.collection_select :assignee_id,
                                   project.users,
                                   :id,
                                   :email,
                                   { include_blank: "Unassigned" },
                                   class: "block w-full rounded-xl border border-slate-200 text-sm bg-slate-50/50 p-3
                                     text-slate-750 cursor-pointer" %>
      </div>
    <% else %>
      <div class="p-4 bg-slate-50 border border-slate-200 rounded-xl">
        <span class="text-xs text-slate-400 font-semibold uppercase">Assignee</span>
        <div class="font-medium text-slate-700 mt-1 text-sm"><%= task.assignee&.email || "Unassigned" %></div>
      </div>
    <% end %>

    <% if permitted_attrs.include?(:status) %>
      <div>
        <%= form.label :status, class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= form.select :status,
                        Task.statuses.keys.map { |s| [s.humanize, s] },
                        {},
                        class: "block w-full rounded-xl border border-slate-200 text-sm bg-slate-50/50 p-3
                          text-slate-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-4 pt-4">
    <%= form.submit class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold text-sm rounded-xl
      shadow-md shadow-indigo-150 transition-all cursor-pointer font-outfit" %>
    <%= link_to "Cancel", project_tasks_path(project), class: "px-5 py-2.5 bg-white border border-slate-200
      hover:bg-slate-50 text-slate-700 font-semibold text-sm rounded-xl transition" %>
  </div>
<% end %>
