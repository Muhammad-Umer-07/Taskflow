<div class="space-y-6 max-w-5xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-slate-200 pb-6">
    <div>
      <%= link_to project_path(@project), class: "inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-800 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to project
      <% end %>
      <h1 class="text-3xl font-extrabold text-slate-900 font-outfit mt-3">Tasks - <%= @project.title %></h1>
      <p class="text-slate-500 mt-1">Manage, dispatch, and track project tasks.</p>
    </div>
    <div>
      <% if policy(Task.new(project: @project)).create? %>
        <%= link_to new_project_task_path(@project), class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold text-sm rounded-xl shadow-md shadow-indigo-100 transition-all font-outfit" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Add Task
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @tasks.any? %>
    <div class="bg-white border border-slate-200/80 rounded-2xl overflow-hidden shadow-sm">
      <table class="min-w-full divide-y divide-slate-100 text-left">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Task Title</th>
            <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Assignee</th>
            <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% @tasks.each do |task| %>
            <tr class="hover:bg-slate-50/50 transition">
              <td class="px-6 py-4">
                <div class="font-semibold text-slate-800 text-sm"><%= task.title %></div>
                <% if task.description.present? %>
                  <div class="text-xs text-slate-400 line-clamp-1 mt-0.5"><%= task.description %></div>
                <% end %>
              </td>
              <td class="px-6 py-4">
                <span class="text-sm text-slate-600"><%= task.assignee&.email || "Unassigned" %></span>
              </td>
              <td class="px-6 py-4">
                <% if task.todo? %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-rose-50 text-rose-705">
                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> To Do
                  </span>
                <% elsif task.in_progress? %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-750">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> In Progress
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-750">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Done
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm font-semibold flex items-center gap-4">
                <% if policy(task).update? %>
                  <%= link_to "Edit", edit_project_task_path(@project, task), class: "text-indigo-650 hover:text-indigo-850 transition" %>
                <% end %>
                <% if policy(task).destroy? %>
                  <%= button_to "Delete", [@project, task], method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-rose-650 hover:text-rose-800 transition cursor-pointer font-semibold" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white border border-dashed border-slate-300 rounded-2xl">
      <p class="text-slate-400">No tasks created yet for this project.</p>
    </div>
  <% end %>
</div>