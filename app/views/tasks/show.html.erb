<div class="max-w-3xl mx-auto space-y-6">
  <div class="flex items-start justify-between gap-4 border-b border-slate-200 pb-6">
    <div>
      <%= link_to "Back to tasks", project_tasks_path(@project), class: "text-sm font-semibold text-slate-500
        hover:text-slate-800" %>
      <h1 class="text-3xl font-extrabold text-slate-900 font-outfit mt-3"><%= @task.title %></h1>
      <p class="text-sm text-slate-500 mt-1"><%= @project.title %></p>
    </div>
    <% if policy(@task).update? %>
      <%= link_to "Edit Task", edit_project_task_path(@project, @task), class: "px-4 py-2 bg-indigo-600
        hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl" %>
    <% end %>
  </div>

  <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-5">
    <div>
      <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Description</h2>
      <p class="text-slate-700 mt-2"><%= @task.description.presence || "No description provided." %></p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Assignee</h2>
        <p class="text-slate-700 mt-2"><%= @task.assignee&.email || "Unassigned" %></p>
      </div>
      <div>
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</h2>
        <p class="text-slate-700 mt-2"><%= @task.status.humanize %></p>
      </div>
    </div>
  </div>
</div>
