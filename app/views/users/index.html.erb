<div class="space-y-6 max-w-5xl mx-auto">
  <div>
    <h1 class="text-3xl font-extrabold text-slate-900 font-outfit">Manage Users</h1>
    <p class="text-slate-500 mt-1">Review accounts and assign application roles.</p>
  </div>

  <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
    <table class="min-w-full divide-y divide-slate-100 text-left">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Email</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Role</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @users.each do |user| %>
          <tr>
            <td class="px-6 py-4 text-sm font-semibold text-slate-700"><%= user.email %></td>
            <td class="px-6 py-4 text-sm text-slate-600"><%= user.role.humanize %></td>
            <td class="px-6 py-4 flex items-center gap-3">
              <%= form_with model: user, class: "flex items-center gap-3" do |form| %>
                <%= form.select :role, User.roles.keys.map { |role| [role.humanize, role] }, {}, class: "rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" %>
                <%= form.submit "Update", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg cursor-pointer" %>
              <% end %>
              <% unless user == current_user %>
                <%= button_to "Delete", user_path(user), method: :delete, data: { turbo_confirm: "Delete #{user.email}? This cannot be undone." }, class: "px-4 py-2 bg-rose-50 hover:bg-rose-100 text-rose-700 text-sm font-semibold rounded-lg cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
